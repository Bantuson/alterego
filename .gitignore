# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
dist/
build/

# uv keeps its lockfile in git (reproducible installs) but not its cache
.uv-cache/

# Recordings and renders are big binary files — never commit them.
# Keep them in these folders so git ignores them automatically.
recordings/
renders/

# Your alter-ego seed. It's the key to your public identity — if it
# leaks, anyone can reproduce (or invert) your disguise. Never commit.
alterego.json

# Editor / OS noise
.vscode/
.idea/
Thumbs.db

# Per-render staging for the clip command - may contain YOUR footage.
remotion/public/
