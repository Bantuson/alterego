# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
dist/
build/

# uv keeps its lockfile in git (reproducible installs) but not its cache
.uv-cache/

# Recordings and renders are big binary files — never commit them.
# Keep them in these folders so git ignores them automatically.
recordings/
renders/

# Your alter-ego identities. They're the keys to your public personas —
# if they leak, anyone can reproduce (or invert) your disguises.
alterego.json
identities/

# Cached face scans for the studio UI: literal biometric geometry.
# Never leaves this machine, never enters git.
.alterego-cache/

# Editor / OS noise
.vscode/
.idea/
Thumbs.db

# Per-render staging for the clip command - may contain YOUR footage.
remotion/public/
